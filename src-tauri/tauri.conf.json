{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeM",
  "version": "0.1.0",
  "identifier": "com.mnl.codem",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeM",
        "width": 1240,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["acrylic"]
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob: asset: http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../dist-server"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
