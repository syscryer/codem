{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeM",
  "version": "0.1.17",
  "identifier": "com.mnl.codem",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodeM",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"]
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob: asset: http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg", "deb", "rpm", "appimage"],
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "CodeM desktop shell",
    "longDescription": "CodeM is a local desktop shell for AI coding agents, conversations, workspaces, Git review, and terminal workflows.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/installer.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["SimpChinese", "English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUyNzIzOTU1M0FEMEU4QUUKUldTdTZOQTZWVGx5NHNOZFBtZkNwRzVEVTNvL3BWTHlJQ0NJVlJHVmdtc1grUStZSzdqcjZqQm0K",
      "endpoints": [
        "https://github.com/syscryer/codem/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
