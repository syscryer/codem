{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "server",
    "src/lib/review-ignore-patterns.ts",
    "src/lib/input-content-blocks.ts",
    "src/types.ts",
    "vite.config.ts"
  ]
}
